using System;
using System.Drawing;
using System.Windows.Forms;

namespace jogoSpace
{
    public partial class MainForm : Form
    {
        // global var
        PictureBox fundo = new PictureBox();
        PictureBox naveJogador = new PictureBox();
        PictureBox naveInimigo = new PictureBox();
        PictureBox tiroJogador = new PictureBox();
        PictureBox tiroInimigo = new PictureBox();
        Label lbl_hpinimigo = new Label();
        Label lbl_hpjogador = new Label();
        int hpInimigo = 100;
        int hpJogador = 100;

        // gameTimer
        Timer gameTimer = new Timer();

        // criando controles
        int sentidoInimigo = 1;
        int velocidadeInimigo = 5;
        int sentidoTiro = 1;
        int velocidadeTiro = 25;
        bool tiroAtivo = false;
        bool tiroInimigoAtivo = false;

        // criando Random
        Random rnd = new Random();

        public MainForm() // Método construtor
        {
            InitializeComponent();

            // Configurando mainForm
            Width = 1920;
            Height = 1080;
            FormBorderStyle = FormBorderStyle.None;
            this.WindowState = FormWindowState.Maximized;
            BackColor = Color.Black; 
            KeyPreview = true;

            // Fundo
            fundo.Parent = this;
            fundo.Dock = DockStyle.Fill;
            fundo.SizeMode = PictureBoxSizeMode.StretchImage; 
            fundo.BackColor = Color.Black; 
            fundo.Load("fundo.png"); 

            // Label do Hitpoint Inimigo
            lbl_hpinimigo.Parent = fundo;
            lbl_hpinimigo.Left = 1300;
            lbl_hpinimigo.Top = 800;
            lbl_hpinimigo.ForeColor = Color.Aqua;
            lbl_hpinimigo.Font = new Font("Arial", 14);
            lbl_hpinimigo.Text = "HP Inimigo: " + hpInimigo;
            lbl_hpinimigo.AutoSize = true;

            // Label do Hitpoint Jogador
            lbl_hpjogador.Parent = fundo;
            lbl_hpjogador.Left = 75;
            lbl_hpjogador.Top = 800;
            lbl_hpjogador.ForeColor = Color.Aqua;
            lbl_hpjogador.Font = new Font("Arial", 14);
            lbl_hpjogador.Text = "HP Jogador: " + hpJogador;
            lbl_hpjogador.AutoSize = true;

            // naveJogador
            naveJogador.Parent = fundo; 
            naveJogador.Width = 123; 
            naveJogador.Height = 47; 
            naveJogador.SizeMode = PictureBoxSizeMode.StretchImage; 
            naveJogador.Load("naveJogador.png");
            naveJogador.BackColor = Color.Transparent; 
            naveJogador.Left = 100; 
            naveJogador.Top = 420;   

            // naveInimigo
            naveInimigo.Parent = fundo; 
            naveInimigo.Width = 118; 
            naveInimigo.Height = 48; 
            naveInimigo.SizeMode = PictureBoxSizeMode.StretchImage; 
            naveInimigo.Load("naveInimigo.png"); 
            naveInimigo.BackColor = Color.Transparent; 
            naveInimigo.Left = 1250;
            naveInimigo.Top = 200; 

            // tiroJogador
            tiroJogador.Parent = fundo; 
            tiroJogador.Width = 30; 
            tiroJogador.Height = 10;
            tiroJogador.SizeMode = PictureBoxSizeMode.StretchImage; 
            tiroJogador.Load("tiroJogador.png"); 
            tiroJogador.BackColor = Color.Transparent; 
            tiroJogador.Left = -200; 
            tiroJogador.Top = 420;

            // tiroInimigo
            tiroInimigo.Parent = fundo;
            tiroInimigo.Width = 30;
            tiroInimigo.Height = 10;
            tiroInimigo.SizeMode = PictureBoxSizeMode.StretchImage;
            tiroInimigo.Load("tiroInimigo.png");
            tiroInimigo.BackColor = Color.Transparent;
            tiroInimigo.Left = -200;
            tiroInimigo.Top = 420;

            // configurando gameTimer
            gameTimer.Interval = 9; 
            gameTimer.Enabled = true;
            gameTimer.Tick += GameTimerTick;

            this.KeyDown += MainFormKeyDown;
        }
        void MainFormKeyDown(object sender, KeyEventArgs e)
        {
            // Movimentação do jogador
            if (e.KeyCode == Keys.Escape)
                Application.Exit();
            if (e.KeyCode == Keys.W)
                naveJogador.Top -= 20; 
            if (e.KeyCode == Keys.S)
                naveJogador.Top += 20; 
            if (e.KeyCode == Keys.D)
                naveJogador.Left += 20; 
            if (e.KeyCode == Keys.A)
                naveJogador.Left -= 20;

            // Limites do jogador
            if (naveJogador.Left >= fundo.Width - naveJogador.Width)
                naveJogador.Left = fundo.Width - naveJogador.Width;
            if (naveJogador.Left <= 0)
                naveJogador.Left = 0;
            if (naveJogador.Top > fundo.Height - naveJogador.Height)
                naveJogador.Top = fundo.Height - naveJogador.Height;
            if (naveJogador.Top <= 0)
                naveJogador.Top = 0;

            // Atirar
            if (e.KeyCode == Keys.Space && !tiroAtivo)
            {
                tiroAtivo = true;
                tiroJogador.Left = naveJogador.Left + naveJogador.Width; 
                tiroJogador.Top = naveJogador.Top + (naveJogador.Height / 2) - (tiroJogador.Height / 2);
            }

        }
        private void GameTimerTick(object sender, EventArgs e)
        {
            // Movimentação do inimigo
            naveInimigo.Top += sentidoInimigo * velocidadeInimigo;

            // Clamping do inimigo
            if (naveInimigo.Top >= fundo.Height - naveInimigo.Height || naveInimigo.Top <= 0)
                sentidoInimigo = -sentidoInimigo; 

            // Movimentação e Clamping do tiro
            if (tiroAtivo)
                tiroJogador.Left += velocidadeTiro * sentidoTiro; 
            if (tiroJogador.Left >= fundo.Width && tiroAtivo) 
            {
                tiroAtivo = false; 
                tiroJogador.Left = -200; 
            }

            // Tiro do inimigo
            if (!tiroInimigoAtivo && rnd.Next(10, 21) == 10)
            {
                tiroInimigoAtivo = true;
                tiroInimigo.Left = naveInimigo.Left;
                tiroInimigo.Top = naveInimigo.Top + naveInimigo.Height / 2;
            }
            if (tiroInimigoAtivo)
                tiroInimigo.Left -= velocidadeTiro;
            if (tiroInimigo.Left < 0)
            {
                tiroInimigoAtivo = false;
                tiroInimigo.Left = -100;
            }

            // Teste de colisão entre o tiroJogador e o inimigo
            if (tiroJogador.Bounds.IntersectsWith(naveInimigo.Bounds))
            {
                tiroJogador.Left = -200;
                tiroAtivo = false;

                hpInimigo -= rnd.Next(10, 21);
                lbl_hpinimigo.Text = "HP Inimigo: " + hpInimigo; 

                if (hpInimigo <= 0) 
                {   
                    naveInimigo.Left = 5000;
                    lbl_hpinimigo.Text = "HP Inimigo: 0";
                    MessageBox.Show("Você ganhou!");
                    Dispose();
                }
            }

            // Teste de colisão entre o tiroInimigo e o jogador
            if (tiroInimigo.Bounds.IntersectsWith(naveJogador.Bounds))
            {
                tiroInimigoAtivo = false;
                tiroInimigo.Left = -100;

                hpJogador -= rnd.Next(5, 15);
                lbl_hpjogador.Text = "HP Jogador: " + hpJogador;

                if (hpJogador <= 0)
                {
                    naveJogador.Left = -500;
                    lbl_hpjogador.Text = "HP Jogador: 0";
                    MessageBox.Show("Você perdeu!");
                    Dispose();    
                }
            }
        }
    }
}
